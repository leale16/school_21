@startuml
!define table class

' =============================================
' Сущности
' =============================================

table "Заказ" as order {
    * ID заказа : INTEGER <<PK>>
    --
    дата/время поступления : DATETIME
    ID оператора : INTEGER <<FK>>
    ID поставщика : INTEGER <<FK>>
    точка комплектации : STRING
    место доставки : STRING
    срок доставки : DATETIME
    состав заказа : STRING
    статус : ENUM
    ID курьера : INTEGER <<FK>>
}

table "Курьер" as courier {
    * ID курьера : INTEGER <<PK>>
    --
    ФИО : STRING
    контактный телефон : VARCHAR
    статус : ENUM
    данные для начисления оплаты : VARCHAR
}

table "Диспетчер" as dispatcher {
    * ID диспетчера : INTEGER <<PK>>
    --
    ФИО : STRING
    email : VARCHAR
    контактный телефон : VARCHAR
}

table "Оператор" as operator {
    * ID оператора : INTEGER <<PK>>
    --
    ФИО : STRING
    email : VARCHAR
    контактный телефон : VARCHAR
}

table "Поставщик" as supplier {
    * ID поставщика : INTEGER <<PK>>
    --
    наименование : STRING
    email : VARCHAR
    контактный телефон : VARCHAR
}

table "Клиент" as client {
    * ID клиента : INTEGER <<PK>>
    --
    ФИО : STRING
    email : VARCHAR
    контактный телефон : VARCHAR
    адрес доставки: STRING
}

table "Оплата" as payment {
    * ID оплаты : INTEGER <<PK>>
    --
    ID курьера : INTEGER <<FK>>
    ID заказа : INTEGER <<FK>>
    сумма : DECIMAL
    дата начисления : DATE
    статус : ENUM
}

table "Доставка" as delivery {
    * ID доставки : INTEGER <<PK>>
    --
    ID заказа : INTEGER <<FK>>
    ID курьера : INTEGER <<FK>>
    адрес : STRING
    дата : DATE
    время : TIME
    статус : ENUM
}

table "Отзыв" as review {
    * ID отзыва : INTEGER <<PK>>
    --
    ID заказа : INTEGER <<FK>>
    ID курьера : INTEGER <<FK>>
    ID клиента : INTEGER <<FK>>
    оценка : INTEGER
    комментарий : STRING
    дата/время создания : DATETIME
}

table "Администратор" as administrator {
    * ID администратора : INTEGER <<PK>>
    --
    ФИО : VARCHAR
    email : VARCHAR
    контактный телефон : VARCHAR
}

' =============================================
' Развязочные таблицы для связей М:М
' =============================================

table "Курьер_Доставка" as courier_delivery {
    * ID записи : INTEGER <<PK>>
    --
    ID курьера : INTEGER <<FK>>
    ID доставки : INTEGER <<FK>>
}

table "Заказ_Доставка" as order_delivery {
    * ID записи : INTEGER <<PK>>
    --
    ID заказа : INTEGER <<FK>>
    ID доставки : INTEGER <<FK>>
}

' =============================================
' Связи (глаголы и множественность)
' =============================================

' Оператор создает Заказ
operator ||--o{ order : "создает"

' Поставщик предоставляет Заказ
supplier ||--o{ order : "предоставляет"

' Курьер выполняет Заказ (назначается на заказ)
courier ||--o{ order : "назначается на"

' Диспетчер переназначает Заказ (связь через атрибут, но для логики указываем)
dispatcher ||--o{ order : "переназначает"

' Клиент оформляет Заказ
client ||--o{ order : "оформляет"

' Заказ имеет Оплату
order ||--|| payment : "имеет"

' Заказ имеет Доставку (один заказ может иметь несколько попыток доставки)
order ||--o{ delivery : "имеет"

' Курьер осуществляет Доставку
courier ||--o{ delivery : "осуществляет"

' Курьер получает Оплату
' Клиент производит Оплату
courier ||--o{ payment : "получает"
client ||--o{ payment : "производит"

' Клиент оставляет Отзыв на Доставку
client ||--o{ review : "оставляет"

' Курьер получает Отзыв
courier ||--o{ review : "получает"

' Заказ связан с Отзывом
order ||--|| review : "имеет"

' Администратор регистрирует Курьера
administrator ||--o{ courier : "регистрирует"

' Администратор регистрирует Диспетчера
administrator ||--o{ dispatcher : "регистрирует"

' Администратор регистрирует Оператора
administrator ||--o{ operator : "регистрирует"

' =============================================
' Связи М:М через развязочные таблицы
' =============================================

' Курьер может участвовать во множестве Доставок, Доставка может выполняться несколькими курьерами (при переназначении)
courier ||--o{ courier_delivery : "участвует в"
delivery ||--o{ courier_delivery : "выполняется"

' Заказ может иметь несколько Доставок (повторные попытки), Доставка относится к одному Заказу (связь уже 1:М, но для истории используем развязочную)
order ||--o{ order_delivery : "связан с"
delivery ||--o{ order_delivery : "относится к"

@enduml