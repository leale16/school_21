@startuml
!theme plain
title DFD уровня 0 — Система управления доставкой заказов (to be)

' === ВНЕШНИЕ СУЩНОСТИ ===
rectangle "Поставщик" as Supplier
rectangle "Клиент" as Client
rectangle "Бухгалтерия" as Accounting
rectangle "Курьер" as Courier
rectangle "Диспетчер" as Dispatcher
rectangle "Оператор" as Operator
rectangle "Администратор" as Admin

' === ХРАНИЛИЩА ДАННЫХ ===
storage "order\n(Заказы)" as D_order
storage "courier\n(Курьеры)" as D_courier
storage "delivery\n(Доставки)" as D_delivery
storage "review\n(Отзывы)" as D_review
storage "payment\n(Оплата)" as D_payment
storage "supplier\n(Поставщики)" as D_supplier
storage "client\n(Клиенты)" as D_client

' === ПРОЦЕССЫ ===
usecase "1. Управлять\nзаказами" as P1
usecase "2. Управлять\nкурьерами" as P2
usecase "3. Управлять\nдоставками" as P3
usecase "4. Управлять\nотзывами" as P4
usecase "5. Управлять\nоплатой" as P5
usecase "6. Управлять\nинтеграцией с бухгалтерией" as P6

' ===== ПОТОКИ ДАННЫХ =====

' === Оператор ===
Operator --> P1 : Данные заказа

' === Администратор ===
Admin --> P2 : Данные курьера

' === Диспетчер ===
Dispatcher --> P3 : Переназначение заказа

' === Курьер ===
Courier <-- P2 : Список свободных заказов
Courier --> P2 : Выбор и бронирование заказа
Courier --> P3 : Отметка о получении заказа
Courier --> P3 : Отметка о доставке
Courier <-- P5 : Начисленная оплата

' === Клиент ===
Client --> P4 : Оценка и отзыв о доставке
Client <-- P4 : Приглашение оценить доставку

' === Поставщик ===
Supplier <-- P6 : Данные о заказах для расчёта

' === Бухгалтерия (внешняя система) ===
Accounting <-- P6 : Данные о поступивших заказах
Accounting <-- P6 : Данные о выполненных доставках

' === Процесс 1. Управлять заказами ===
P1 --> D_order : Сохранение заказа
P1 <-- D_supplier : Данные поставщика
P1 <-- D_client : Данные клиента

' === Процесс 2. Управлять курьерами ===
P2 --> D_courier : Регистрация курьера
P2 <-- D_order : Свободные заказы
P2 --> D_order : Бронирование заказа

' === Процесс 3. Управлять доставками ===
P3 --> D_delivery : Сохранение доставки
P3 <-- D_order : Данные заказа
P3 --> D_order : Обновление статуса заказа

' === Процесс 4. Управлять отзывами ===
P4 --> D_review : Сохранение отзыва
P4 <-- D_delivery : Данные о доставке
P4 <-- Client : Оценка и отзыв
P4 --> Client : Приглашение оценить

' === Процесс 5. Управлять оплатой ===
P5 --> D_payment : Начисление оплаты
P5 <-- D_delivery : Данные о доставке
P5 --> Courier : Начисленная оплата

' === Процесс 6. Управлять интеграцией с бухгалтерией ===
P6 <-- D_order : Данные заказов
P6 <-- D_delivery : Данные доставок
P6 --> Supplier : Данные для поставщиков
P6 --> Accounting : Данные для бухгалтерии

@enduml